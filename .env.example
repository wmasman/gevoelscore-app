# Path to the external personal-data folder.
#
# All scripts in docs/research/pipeline/ resolve data paths against this.
# This folder is NEVER committed to git — it lives outside the repo.
#
# Structure (per docs/research/methodology/methodology.md target layout):
#   $GEVOELSCORE_DATA_PATH/
#     raw/             original GDPR exports, PDFs, Excel
#     processed/       intermediate per-source CSVs
#     unified/         per_day_master.csv (the unified dataset)
#     reviews/         triage / review CSVs with raw text
#
# Copy this file to .env (gitignored) and edit the path to match your machine.
GEVOELSCORE_DATA_PATH=C:/Users/Gebruiker/Documents/gevoelscore-data
