# gevoelscore-app — frontend env var template
#
# Copy to `.env.local` (gitignored) for local development.
# Production values live on Fly secrets (fly secrets set --app gevoelscore-frontend ...).
#
# Public vars (NEXT_PUBLIC_*) end up in the client bundle — never put secrets there.
# Server-only vars stay in Route Handlers and `getServerSideProps`-equivalent code.

# === Public (client bundle) ===
NEXT_PUBLIC_DIRECTUS_URL=https://gevoelscore-backend.fly.dev
NEXT_PUBLIC_APP_URL=https://gevoelscore-frontend.fly.dev

# === Server-only (Route Handlers / server components) ===
# Internal Fly network URL — server reaches Directus directly without going through public TLS.
DIRECTUS_URL=http://gevoelscore-backend.internal:8055
