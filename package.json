{
  "name": "gevoelscore-app",
  "version": "0.0.0-pre-prototype",
  "private": true,
  "description": "Personal Long COVID daily-tracking app — Next.js 15 PWA + Directus backend",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:live": "playwright test --config=playwright.live-stack.config.ts",
    "test:all": "vitest run && playwright test",
    "audit": "npm audit --audit-level=high",
    "verify": "npm run lint && npm run typecheck && npm test",
    "verify:full": "npm run verify && npm run audit && npm run test:e2e",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "pre-push": "npm run verify"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,js}": "eslint --max-warnings 0"
  },
  "dependencies": {
    "@directus/sdk": "^18.0.3",
    "clsx": "^2.1.1",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/eslintrc": "^3.0.0",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-security": "^4.0.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  }
}
