# gevoelscore Directus operational scripts — env var template
#
# Copy this file to `.env.local` (gitignored) and fill in your values,
# OR set the env vars directly in your shell when running scripts.
#
# NEVER commit a file with real values. The .env* pattern is gitignored
# globally (see repo root .gitignore).

# Where to hit. Defaults to production if not set.
DIRECTUS_URL=https://gevoelscore-backend.fly.dev

# Static token for the admin user, used by directus/scripts/*.mjs.
# Generate via Directus admin UI: User Profile → Token → Generate.
# Revoke + regenerate on suspicion of leak (e.g. if it appears in a chat transcript).
DIRECTUS_TOKEN=
